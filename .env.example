# ============================================================================
# Donna — env vars (BACKEND)
# ============================================================================
# Copy to .env locally. In production, set these in Render dashboard.

# --- Groq (required) -------------------------------------------------------
# Get a key from https://console.groq.com/keys. Free tier is fine.
GROQ_API_KEY=

# --- Persistence (MongoDB Atlas — primary store) ---------------------------
# Get this from Atlas → Connect → Drivers → Python. URL-encode any special
# characters in the password (@, :, /, etc.).
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=Donna
# Case-sensitive — match exactly what you see in Compass.
MONGODB_DB=Donna

# --- Persistence (ChromaDB — semantic memory, file-based) ------------------
# Vector index for "remember when we…" recall. No separate service.
CHROMA_DB_PATH=./data/chroma

# --- Scheduler -------------------------------------------------------------
# IANA timezone for morning briefing / EOD wrap jobs.
SCHEDULER_TZ=America/New_York

# --- CORS ------------------------------------------------------------------
# Comma-separated list of allowed frontend origins.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Web Push (optional but recommended) -----------------------------------
# Generate with:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:admin@donna.local


# ============================================================================
# Donna — env vars (FRONTEND — set these in Vercel)
# ============================================================================
# These are NOT read by the backend. They live in the Vercel project settings.
#
# NEXT_PUBLIC_API_URL=https://donna-backend.onrender.com
# NEXTAUTH_URL=https://donna.vercel.app
# NEXTAUTH_SECRET=                 # openssl rand -base64 32
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
